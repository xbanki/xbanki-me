{
	"name": "@xbanki-me/ui",
	"version": "1.0.0",
	"files": [
		"dist/lib"
	],
	"type": "module",
	"main": "./dist/lib/xbanki-me-ui.umd.cjs",
	"module": "./dist/lib/xbanki-me-ui.js",
	"types": "./dist/lib/xbanki-me-ui.d.ts",
	"imports": {
		"~/": [
			"./.storybook/*"
		],
		"@/": [
			"./src/*"
		]
	},
	"exports": {
		".": {
			"types": "./dist/lib/xbanki-me-ui.d.ts",
			"import": "./dist/lib/xbanki-me-ui.js",
			"require": "./dist/lib/xbanki-me-ui.umd.cjs"
		},
		"./tailwind": "./dist/lib/assets/theme.css"
	},
	"scripts": {
		"build": "yarn build:lib",
		"build:all": "yarn build:lib && yarn build:docs",
		"build:docs": "storybook build -o dist/docs",
		"build:lib": "vue-tsc --noEmit && vite build",
		"dev": "storybook dev -p 6006 --no-open",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"tidy": "corepack yarn run format && corepack yarn run lint:fix"
	},
	"dependencies": {
		"animejs": "^4.3.6",
		"vue": "^3.5.32"
	},
	"devDependencies": {
		"@laynezh/vite-plugin-lib-assets": "2.1.3",
		"@rollup-extras/plugin-copy": "^2.1.0",
		"@storybook-community/storybook-dark-mode": "^7.1.2",
		"@storybook/addon-docs": "^10.3.5",
		"@storybook/addon-themes": "^10.3.5",
		"@storybook/vue3-vite": "^10.3.5",
		"@tailwindcss/vite": "^4.2.3",
		"@vitejs/plugin-vue": "^6.0.6",
		"@xbanki-me/config": "workspace:^",
		"@xbanki-me/fetch-secure-blob": "workspace:^",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"storybook": "^10.3.5",
		"tailwindcss": "^4.2.3",
		"ts-deepmerge": "^7.0.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.9",
		"vite-plugin-dts": "^4.5.4",
		"vite-plugin-lib-inject-css": "^2.2.2",
		"vue-macros": "^3.1.2",
		"vue-tsc": "^3.2.7"
	},
	"packageManager": "yarn@4.9.2"
}
