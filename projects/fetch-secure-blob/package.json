{
	"name": "@xbanki-me/fetch-secure-blob",
	"version": "1.0.0",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/library.cjs",
	"module": "./dist/library.mjs",
	"types": "./dist/library.d.cts",
	"exports": {
		".": {
			"import": {
				"default": "./dist/library.mjs",
				"types": "./dist/library.d.mts"
			},
			"require": {
				"default": "./dist/library.cjs",
				"types": "./dist/library.d.cts"
			}
		}
	},
	"scripts": {
		"build": "tsdown --minify --format esm --format cjs",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"tidy": "corepack yarn run format && corepack yarn run lint:fix"
	},
	"dependencies": {
		"@vercel/blob": "^2.3.3",
		"ci-info": "^4.4.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"dotenv": "^17.4.2",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"ts-deepmerge": "^7.0.3",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.3"
	},
	"packageManager": "yarn@4.9.2"
}
