{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "lib": ["DOM.Iterable", "ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext",
    "types": ["vue-macros/macros-global"]
  },
  "exclude": ["node_modules/", ".storybook/", "build/", "dist/"],
  "include": ["**/*.json", "**/*.vue", "**/*.ts"],
  "vueCompilerOptions": {
    "plugins": ["vue-macros/volar"]
  }
}
