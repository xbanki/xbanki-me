    "@tailwindcss/typography": "^0.5.16",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-formatter-table": "^7.32.1",
    "eslint-plugin-vue": "^10.0.0",
    "postcss": "^8.5.3",
