{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "BLOB_READ_WRITE_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/*"
      ]
    },
    "build:docs": {
      "dependsOn": [
        "@xbanki-me/fetch-secure-blob#build",
        "^build:docs"
      ],
      "outputs": [
        "dist/docs/*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "tidy": {
      "cache": false
    }
  },
  "ui": "tui"
}
